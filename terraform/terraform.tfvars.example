# terraform.tfvars.example
# Copy to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit it.

hcloud_token    = "YOUR_HETZNER_API_TOKEN_HERE"
ssh_key_ids     = [111111111, 222222222]   # Hetzner SSH key IDs
ssh_port        = 2222
admin_ip        = "YOUR.PUBLIC.IP/32"
cp_server_type  = "cpx31"
cp_image        = "alma-9"
cp_location     = "ash"                    # ash | nbg1 | fsn1 | hel1 | hil
vps_server_type = "cpx31"                  # cpx31 (4vCPU/8GB) recommended for full stack
vps_image       = "debian-12"
vps_location    = "hil"                    # may differ from cp_location if cpx31 unavailable in ash
